}
}
data_o[, time_column]
time_format = "%Y-%m-%d %H:%M:%S"
start = "2020-01-01 00:00:00"
end = "2020-12-31 23:59:59"
as.POSIXct(data_o[, time_column],
tz = Sys.timezone(location = TRUE),
format = time_format)
as.POSIXct(data_o[c(1:5), time_column],
