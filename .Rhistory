cool_function2 <- function(x) {
x <- sort(as.Date(x))
min_diff <- min(diff(x))
case_when(
min_diff >= years(1)   ~ "year",
min_diff >= months(1)  ~ "month",
min_diff >= weeks(1)   ~ "week",
min_diff >= days(1)    ~ "day",
TRUE                   ~ "smaller"
)
}
dates_m <- c("2021-05-01", "2021-06-01", "2021-07-01")
dates_d <- c("2021-05-01", "2021-05-02", "2021-05-14")
cool_function2(dates_m)
cool_function2 <- function(x) {
x <- sort(as.Date(x))
min_diff <- min(diff(x))
dplyr::case_when(
min_diff >= years(1)   ~ "year",
min_diff >= months(1)  ~ "month",
min_diff >= weeks(1)   ~ "week",
min_diff >= days(1)    ~ "day",
TRUE                   ~ "smaller"
)
}
cool_function2(dates_m)
cool_function2 <- function(x) {
x <- sort(as.Date(x))
min_diff <- min(diff(x))
dplyr::case_when(
min_diff >= lubridate::years(1)   ~ "year",
min_diff >= lubridate::months(1)  ~ "month",
min_diff >= lubridate::weeks(1)   ~ "week",
min_diff >= lubridate::days(1)    ~ "day",
TRUE                   ~ "smaller"
)
}
cool_function2(dates_m)
remove(cool_function2())
remove(cool_function2
)
cool_function <- function(x) {
x <- sort(as.Date(x))
d <- min(diff(x))
if (d >= 365) return("year")
if (d >= 28)  return("month")
if (d >= 7)   return("week")
if (d >= 1)   return("day")
"subday"
}
cool_function(dates_m)
cool_function(dates_d)
