data <- data[stats::complete.cases(data), ]
c <- stats::cor(data)
### -- smol function from stack overflow for cor-test -- ##
cor.mtest <- function(mat, ...) {
mat <- as.matrix(mat)
n <- ncol(mat)
p.mat<- matrix(NA, n, n)
diag(p.mat) <- 0
for (i in 1:(n - 1)) {
for (j in (i + 1):n) {
tmp <- stats::cor.test(mat[, i], mat[, j], ...)
p.mat[i, j] <- p.mat[j, i] <- tmp$p.value
}
}
colnames(p.mat) <- rownames(p.mat) <- colnames(mat)
p.mat
};
# matrix of the p-value of the correlation
p.mat <- cor.mtest(data)
round(utils::head(p.mat[, 1:5]), 6)
# Now with a variable for sensor
corlist <- list()
sensor_names <- names(data)[c(1:length(resp))]
message("Finding autocorrelating predictors for these sensors [", paste(sensor_names, collapse = ", "),"].")
if(length(resp) == 1){
corlist[[1]] <- lares::corr_var(
df = data,
var = sensor_names[1],
max_pvalue = max_pvalue,
top = 50,
plot = FALSE)
} else {
for (i in 1:length(resp)){
corlist[[i]] <- lares::corr_var(
df = data,
var = sensor_names[i],
max_pvalue = max_pvalue,
ignore = sensor_names[-i],
top = 50,
plot = FALSE
)
}
} # end if-conditions
max_pvalue = 0.05
if(length(resp) == 1){
corlist[[1]] <- lares::corr_var(
df = data,
var = sensor_names[1],
max_pvalue = max_pvalue,
top = 50,
plot = FALSE)
} else {
for (i in 1:length(resp)){
corlist[[i]] <- lares::corr_var(
df = data,
var = sensor_names[i],
max_pvalue = max_pvalue,
ignore = sensor_names[-i],
top = 50,
plot = FALSE
)
}
} # end if-conditions
for (i in 1:length(corlist)){
df <- corlist[[i]]
var <- df[df$corr <= 0, ]
if(nrow(var) == 0){
warning(paste0("No significant autocorrelations found for ", sensor_names[i],". Maybe check max_pvalue."))
} else {
utils::write.csv(
var,
file.path(
envrmt$path_statistics,
paste0(
sensor_names[i],
"_delect.csv"
)
)
)
}
} # end corlist-loop
message("Done with finding autocorrelations for these sensors [",paste(sensor_names, collapse = ", "),"].")
saveRDS(
sensor_names,
file.path(
envrmt$path_tmp,
"sensor_names.rds"
)
)
